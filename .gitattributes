# Excluir pastas de desenvolvimento do ZIP gerado pelo GitHub
.github export-ignore
.vscode export-ignore
.agent export-ignore
tests export-ignore
docs export-ignore
scratch export-ignore
artefacts export-ignore
temp export-ignore

# Tratar scripts como texto para garantir que nao quebrem no Windows
*.bat text eol=crlf
*.ps1 text eol=crlf
*.py text eol=lf
*.md text eol=lf
